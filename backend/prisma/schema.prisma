generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  password     String
  transactions Transaction[]
  categories   Category[]    // A relação inversa que faltava
}

model Category {
  id           String          @id @default(uuid())
  name         String
  type         TransactionType
  transactions Transaction[]

  userId       String          // O campo que faltava
  user         User            @relation(fields: [userId], references: [id])
}

model Transaction {
  id          String   @id @default(uuid())
  title       String
  amount      Float
  type        TransactionType
  date        DateTime
  
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
}

enum TransactionType {
  INCOME
  EXPENSE
}